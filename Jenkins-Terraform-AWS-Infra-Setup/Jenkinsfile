pipeline {
    agent any

    parameters {
        choice(name: 'action', choices: ['apply', 'destroy'], description: 'Pick the Terraform action to perform')
    }

    environment {
        TF_IN_AUTOMATION = 'true'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/knowledgemateit/Terraform-notes.git'
            }
        }

        stage('Terraform Init') {
            steps {
                // dir() ensures all commands inside happen inside your subfolder
                dir('Jenkins-Terraform-AWS-Infra-Setup') {
                    sh 'terraform init --upgrade'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('Jenkins-Terraform-AWS-Infra-Setup') {
                    sh "terraform plan -out=tfplan"
                }
            }
        }

        stage('Approval Gate') {
            when { expression { params.action == 'apply' } }
            steps {
                input message: "Review the plan above. Proceed with ${params.action}?", ok: "Yes, proceed"
            }
        }

        stage('Terraform Action') {
            steps {
                dir('Jenkins-Terraform-AWS-Infra-Setup') {
                    script {
                        echo "Executing Terraform ${params.action}..."
                        if (params.action == 'apply') {
                            sh 'terraform apply tfplan'
                        } else {
                            // Destroy also needs to run inside the directory to find the state/config
                            sh 'terraform destroy --auto-approve'
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            dir('Jenkins-Terraform-AWS-Infra-Setup') {
                sh 'rm -f tfplan'
            }
        }
    }
}
